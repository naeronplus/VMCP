# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:8080
# Comma-separated origins for production CORS (defaults to PUBLIC_BASE_URL)
CORS_ALLOWED_ORIGINS=
LOG_LEVEL=info

# ── PostgreSQL (Railway managed) ────────────────────
DATABASE_URL=postgresql://pgos:pgos@localhost:5432/pgos

# ── Redis (Railway managed) ─────────────────────────
REDIS_URL=redis://localhost:6379

# ── S3 (worker artifacts only — never Railway volume for workers) ──
# Local MinIO (docker compose): http://localhost:9000
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pgos-artifacts
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ── Auth (RS256 JWT) ────────────────────────────────
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
# Or inline PEM (Railway secrets):
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
JWT_ISSUER=pgos
JWT_AUDIENCE=pgos-api
SESSION_TTL_SECONDS=86400

# ── GitHub App (workflow_dispatch) ──────────────────
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_WORKFLOW_FILE=godot_worker.yml
GITHUB_DEFAULT_REF=main
# true in development by default; set false in production with real App credentials
GITHUB_MOCK=true

# ── Dispatch / scheduling ───────────────────────────
DISPATCH_TIMEOUT_MS=60000
DISPATCH_POLL_INTERVAL_MS=5000
DISPATCH_MAX_CONSECUTIVE_FAILURES=3
HEARTBEAT_INTERVAL_MS=15000
HEARTBEAT_STALE_AFTER_MS=30000
TIER_A_QUEUE_THRESHOLD=3
CALLBACK_TOKEN_TTL_MS=300000
GODOT_DEFAULT_VERSION=4.3.1
REIMPORT_TIMEOUT_MS=300000
REIMPORT_MAX_RETRIES=2

# ── Alerts ──────────────────────────────────────────
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
SMTP_URL=
ADMIN_EMAIL=

# ── Extension sandbox ───────────────────────────────
SANDBOX_SERVICE_URL=http://localhost:8090
SANDBOX_INTERNAL_TOKEN=dev-sandbox-token
# Required in production sandbox-service:
# FIRECRACKER_SOCKET=/var/run/firecracker.sock
# FIRECRACKER_LAUNCHER=/path/to/firecracker-launcher.sh

# ── JWE secret envelope ─────────────────────────────
JWE_SECRET=change-me-to-a-32-byte-or-longer-secret!!

# ── Rate limiting ───────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=30

# ── Bootstrap admin (required in production when no admin exists) ──
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
# Leave empty in dev to use default admin-change-me; REQUIRED in production
BOOTSTRAP_ADMIN_PASSWORD=

# ── Tier scheduling ─────────────────────────────────
TIER_A_ENABLED=true
TIER_B_ENABLED=true

# ── Orchestrator cache (local only — not worker artifacts) ──
ORCHESTRATOR_CACHE_DIR=./.cache/pgos

# ── Commit-agent (cross-machine fencing validation) ──
# Operator+ JWT/API token used by commit-agent when calling /locks/validate-token
PGOS_AGENT_TOKEN=

# Optional: 90-day agent secret rotation target (BullMQ cron)
AGENT_ROTATE_URL=

# ── Vibrato MCP server (stdio) ──
# PGOS_API_TOKEN=operator-or-admin JWT for MCP tools
# PGOS_BASE_URL=http://localhost:8080

# ── GitHub Actions secrets (set in repo Settings → Secrets, not in .env) ──
# PGOS_BASE_URL=https://your-pgos.example.com
# PGOS_ADMIN_TOKEN=admin JWT for health cron probes
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:8080
# Comma-separated origins for production CORS (defaults to PUBLIC_BASE_URL)
CORS_ALLOWED_ORIGINS=
LOG_LEVEL=info

# ── PostgreSQL (Railway managed) ────────────────────
DATABASE_URL=postgresql://pgos:pgos@localhost:5432/pgos

# ── Redis (Railway managed) ─────────────────────────
REDIS_URL=redis://localhost:6379

# ── S3 (worker artifacts only — never Railway volume for workers) ──
# Local MinIO (docker compose): http://localhost:9000
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pgos-artifacts
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ── Auth (RS256 JWT) ────────────────────────────────
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
# Or inline PEM (Railway secrets):
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
JWT_ISSUER=pgos
JWT_AUDIENCE=pgos-api
SESSION_TTL_SECONDS=86400

# ── GitHub App (workflow_dispatch) ──────────────────
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_WORKFLOW_FILE=godot_worker.yml
GITHUB_DEFAULT_REF=main
# true in development by default; set false in production with real App credentials
GITHUB_MOCK=true
# M-18: local E2E — with GITHUB_MOCK=true, force workflow_dispatch to fail → job DISPATCH_FAILED
GITHUB_MOCK_DISPATCH_FAIL=false
# M-18: mock getRunStatus conclusion when GITHUB_MOCK=true (success|failure|cancelled|…)
GITHUB_MOCK_RUN_CONCLUSION=success

# ── Dispatch / scheduling ───────────────────────────
DISPATCH_TIMEOUT_MS=60000
DISPATCH_POLL_INTERVAL_MS=5000
DISPATCH_MAX_CONSECUTIVE_FAILURES=3
HEARTBEAT_INTERVAL_MS=15000
HEARTBEAT_STALE_AFTER_MS=30000
TIER_A_QUEUE_THRESHOLD=3
CALLBACK_TOKEN_TTL_MS=300000
GODOT_DEFAULT_VERSION=4.3.1
# L-05: wired into dispatch JWE → worker REIMPORT_TIMEOUT_SEC / REIMPORT_MAX_RETRIES
REIMPORT_TIMEOUT_MS=300000
REIMPORT_MAX_RETRIES=2

# ── Alerts ──────────────────────────────────────────
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
SMTP_URL=
ADMIN_EMAIL=

# ── Extension sandbox (M-08: separate Railway service) ──
# Local Compose: http://sandbox:8090 (or localhost:8090 from host)
# Railway orchestrator service MUST point at the sandbox service URL, e.g.:
#   SANDBOX_SERVICE_URL=http://${{sandbox.RAILWAY_PRIVATE_DOMAIN}}:${{sandbox.PORT}}
# See docs/deploy/railway.md
SANDBOX_SERVICE_URL=http://localhost:8090
# Shared bearer between orchestrator and sandbox-service (change in production)
SANDBOX_INTERNAL_TOKEN=dev-sandbox-token
# ENV-03 / H-08: sandbox-service only (not read by orchestrator). Production default:
# SANDBOX_BACKEND=worker_thread
# See packages/sandbox-service/.env.example and docs/deploy/railway.md
# SEC-02 / DEP-01: dedicated bearer for target JIT SSH provisioner (POST /v1/provision).
# MUST match PGOS_PROVISION_TOKEN on each target host running packages/target-provisioner.
# Do not reuse SANDBOX_INTERNAL_TOKEN (production validation rejects equality / sandbox defaults).
PGOS_PROVISION_TOKEN=dev-provision-token
# SEC-01: optional client mTLS PEM paths for orchestrator → target provisioner (recommended prod).
# When either CERT or KEY is set, both are required. Prefer mTLS over bearer-only.
# PGOS_PROVISION_MTLS_CERT=/etc/pgos/provision-client.crt
# PGOS_PROVISION_MTLS_KEY=/etc/pgos/provision-client.key
# PGOS_PROVISION_MTLS_CA=/etc/pgos/provision-ca.crt
# Required in production sandbox-service (Firecracker Path A only; not for worker_thread default):
# FIRECRACKER_SOCKET=/var/run/firecracker.sock
# FIRECRACKER_LAUNCHER=/path/to/firecracker-launcher.sh

# ── JWE secret envelope ─────────────────────────────
JWE_SECRET=change-me-to-a-32-byte-or-longer-secret!!

# ── Rate limiting ───────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=30

# ── Bootstrap admin (required in production when no admin exists) ──
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
# Leave empty in dev to use default admin-change-me; REQUIRED in production
BOOTSTRAP_ADMIN_PASSWORD=

# ── Tier scheduling ─────────────────────────────────
TIER_A_ENABLED=true
TIER_B_ENABLED=true

# ── Orchestrator cache (local only — not worker artifacts; L-05) ──
# Created at orchestrator startup via ensureOrchestratorCacheDir().
ORCHESTRATOR_CACHE_DIR=./.cache/pgos

# ── Commit-agent (cross-machine fencing validation) ──
# ENV-01: Bearer for commit-agent POST /api/v1/locks/validate-token (operator+).
# Cross-ref: packages/commit-agent/README.md (-auth-token / PGOS_AGENT_TOKEN).
# Production warns if empty (fencing validation will fail on targets).
PGOS_AGENT_TOKEN=

# ENV-01: Optional URL for quarterly agent secret rotation (BullMQ secret-rotation cron).
# Leave empty to skip remote rotate call.
AGENT_ROTATE_URL=

# ── Merge outbox / remote structural merge (ENV-02 / H-02) ──
# Service token for POST /api/v1/merge-outbox/:id/complete and merge_apply.yml JWE callback.
# Required in production when structural merge is enabled (default on; set PGOS_STRUCTURAL_MERGE=0 to disable).
# Also configure as GitHub Actions secret PGOS_SERVICE_TOKEN for merge_apply.yml fallback.
PGOS_SERVICE_TOKEN=
# Emergency kill-switch for structural merge + outbox consumer (default: enabled)
# PGOS_STRUCTURAL_MERGE=1
# PGOS_MERGE_MODE=auto

# ── Vibrato MCP server (stdio) ──
# PGOS_API_TOKEN=operator-or-admin JWT for MCP tools
# PGOS_BASE_URL=http://localhost:8080

# ── GitHub Actions secrets (set in repo Settings → Secrets, not in .env) ──
# PGOS_BASE_URL=https://your-pgos.example.com
# PGOS_ADMIN_TOKEN=admin JWT for health cron probes
# PGOS_SERVICE_TOKEN=same as orchestrator PGOS_SERVICE_TOKEN (merge_apply complete fallback)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
